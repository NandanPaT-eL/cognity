# ─── DATABASE ───────────────────────────────
DATABASE_URL=

# ─── REDIS (Upstash) ────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── VECTOR STORE (Pinecone) ────────────────
PINECONE_API_KEY=
PINECONE_INDEX_NAME=cognity-docs

# ─── AI (Gemini - Free Tier) ────────────────
GEMINI_API_KEY=
GEMINI_MODEL=
GEMINI_EMBEDDING_MODEL=

# ─── AUTH (Clerk) ───────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ─── BACKGROUND JOBS (Inngest) ──────────────
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ─── FILE STORAGE (Uploadthing) ─────────────
UPLOADTHING_SECRET=

# ─── EMAIL (Resend) ─────────────────────────
RESEND_API_KEY=

# ─── APP ────────────────────────────────────
PORT=3001
NODE_ENV=development
API_BASE_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
# URL of the dashboard — used for Stripe redirect URLs
DASHBOARD_URL=http://localhost:3000/dashboard

# ─── PRODUCTION (uncomment when deploying) ──────────────────────────────────
# API_BASE_URL=https://api.cognity.com.au
# NEXT_PUBLIC_API_URL=https://api.cognity.com.au/v1
# CORS_ORIGINS=https://cognity.com.au,https://www.cognity.com.au,https://dashboard.cognity.com.au
# DASHBOARD_URL=https://cognity.com.au/dashboard

# ─── STRIPE ─────────────────────────────────

# Secret key — paste in apps/api only (never expose to browser)
STRIPE_SECRET_KEY=sk_live_...

# Webhook signing secret — get from Stripe Dashboard → Webhooks → your endpoint
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs — get from Stripe Dashboard → Products → each price's ID
# Starter plan (recurring monthly)
STRIPE_PRICE_STARTER=price_...
# Growth plan (recurring monthly)
STRIPE_PRICE_GROWTH=price_...
# Lifetime deal (one-time payment)
STRIPE_PRICE_LIFETIME=price_...

# Publishable key — safe to expose to browser (dashboard frontend)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
